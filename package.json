{
  "name": "truss",
  "version": "0.1.0",
  "description": "Local agentic harness with a Bun backend, SSE transport, and React frontend.",
  "type": "module",
  "module": "./src/server/index.ts",
  "bin": {
    "truss": "./index.ts"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "files": [
    "dist/index.js",
    "dist/*.wasm",
    "docs",
    "icon.png",
    "logo.webp",
    "packaging/windows/README.md",
    "public",
    "src",
    "index.ts",
    "README.md"
  ],
  "scripts": {
    "dev": "bun run build:client && bun --watch src/server/index.ts spawn --no-autolaunch",
    "start": "bun run build:client && bun src/server/index.ts spawn --no-autolaunch",
    "truss": "bun src/server/index.ts",
    "build": "bun run build:client && bun build src/server/index.ts --target bun --outdir dist",
    "build:client": "bun run build:client:css && bun run build:client:js",
    "build:client:css": "bun run build:client:sass && bunx @tailwindcss/cli -i src/client/tailwind.css -o public/assets/styles.css",
    "build:client:sass": "sass src/client/styles.scss src/client/styles.generated.css --no-source-map",
    "build:client:js": "bun build src/client/main.tsx --target browser --outdir public/assets --sourcemap=linked",
    "check": "tsc --noEmit",
    "test": "bun test",
    "compile": "bun run build:client && bun build src/server/index.ts --compile --outfile dist/truss",
    "compile:windows": "bun run build:client && bun build src/server/index.ts --compile --outfile dist/truss.exe",
    "package:windows": "powershell -NoProfile -ExecutionPolicy Bypass -File packaging/windows/build-package.ps1",
    "package:windows:installer": "powershell -NoProfile -ExecutionPolicy Bypass -File packaging/windows/build-package.ps1 -BuildInstaller",
    "spawn:scoped": "bun run truss spawn . --no-autolaunch",
    "debug:truss-web-tools": "bun --inspect-brk src/server/index.ts mcp-server truss-web-tools",
    "prepack": "bun run build"
  },
  "dependencies": {
    "@dotenvx/dotenvx": "^1.73.1",
    "@playwright/mcp": "0.0.29",
    "adm-zip": "0.6.0",
    "croner": "^10.0.1",
    "katex": "^0.17.0",
    "pandoc-wasm": "^1.1.0",
    "pdf-parse": "^2.4.5",
    "plantuml-encoder": "^1.4.0",
    "playwright-core": "1.53.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-easy-crop": "^6.0.2",
    "word-extractor": "^1.0.4",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.0",
    "@types/adm-zip": "0.5.8",
    "@types/bun": "^1.3.14",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/word-extractor": "^1.0.6",
    "sass": "^1.96.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3"
  }
}
